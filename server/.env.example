# Database — SQL Server (Prisma provider "sqlserver").
# Local dev uses the Dockerized SQL Server in server/docker-compose.yml.
DATABASE_URL="sqlserver://localhost:1433;database=profile;user=sa;password=Dev_Str0ng_Pass!;encrypt=true;trustServerCertificate=true"
#
# Production (Azure SQL Database) looks like:
# DATABASE_URL="sqlserver://<server>.database.windows.net:1433;database=<db>;user=<user>;password=<password>;encrypt=true;trustServerCertificate=false"

# Signed-cookie session secret (generate a long random string)
JWT_SECRET="change-me-to-a-long-random-string"

# Public-facing origin used to build OAuth redirect URIs and cookie security.
# Dev: the Vite origin (it proxies /auth to this server).
APP_URL="http://localhost:5173"

# Only these emails may access the admin (comma-separated, case-insensitive)
ALLOWED_EMAILS="hjie30@hotmail.com"

# GitHub OAuth App (https://github.com/settings/developers)
# Authorization callback URL: ${APP_URL}/auth/github/callback
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Google OAuth client (https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI: ${APP_URL}/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Server port
PORT="3001"
